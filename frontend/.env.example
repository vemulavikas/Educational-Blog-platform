# Frontend environment variables
# Create a .env file in frontend/ for local development if needed.

# If deploying frontend separately (Vercel/Netlify), set this to your backend URL:
# REACT_APP_API_URL=https://your-backend.onrender.com/api
#
# If deploying as a single Render service (backend serves frontend build), you can omit this.
REACT_APP_API_URL=
